{
	"name": "oaktreelandscaping",
	"version": "1.1.6",
	"private": true,
	"scripts": {
		"dev": "npm run clean && NODE_OPTIONS='--inspect' next dev --webpack -p 3007 --experimental-https",
		"build": "npm run clean && NODE_ENV=production next build --webpack",
		"start": "npm run clean && next build --webpack && next start",
		"lint": "eslint --fix",
		"clean": "rm -rf .next && rm -rf out",
		"generate-site-images": "node ./node_modules/@pixelated-tech/components/dist/scripts/generate-site-images.js",
		"config:vault": "npx tsx ./node_modules/@pixelated-tech/components/dist/scripts/config-vault.ts",
		"config:encrypt": "npm run config:vault -- encrypt src/app/config/pixelated.config.json",
		"config:decrypt": "npm run config:vault -- decrypt src/app/config/pixelated.config.json.enc",
		"release:prep": "npm run update && npm run lint && npm run build",
		"release": "./node_modules/@pixelated-tech/components/dist/scripts/release.sh",
		"update": "bash node_modules/@pixelated-tech/components/dist/scripts/update.sh"
	},
	"dependencies": {
		"@pixelated-tech/components": "^3.15.2",
		"html-entities": "^2.6.0",
		"md5": "^2.3.0",
		"next": "^16.2.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"sass": "^1.99.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"@types/prop-types": "^15.7.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19",
		"eslint": "9.39.4",
		"eslint-config-next": "^16.2.3",
		"typescript": "^6.0.2"
	},
	"optionalDependencies": {
		"eslint": "9.39.4"
	}
}
