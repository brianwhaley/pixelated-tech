{
	"name": "@pixelated-tech/components",
	"version": "3.15.15",
	"type": "module",
	"private": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/brianwhaley/pixelated-components.git"
	},
	"homepage": "https://github.com/brianwhaley/pixelated-components#readme",
	"bugs": {
		"url": "https://github.com/brianwhaley/pixelated-components/issues"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"author": {
		"name": "Pixelated Technologies",
		"url": "https://www.pixelated.tech/"
	},
	"description": "Pixelated UI Components",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/types/index.d.ts",
	"sideEffects": [
		"*.css",
		"*.scss"
	],
	"files": [
		"dist"
	],
	"directories": {
		"doc": "docs"
	},
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/types/index.server.d.ts",
			"import": "./dist/index.server.js",
			"default": "./dist/index.server.js"
		},
		"./adminserver": {
			"types": "./dist/types/index.adminserver.d.ts",
			"import": "./dist/index.adminserver.js",
			"default": "./dist/index.adminserver.js"
		},
		"./adminclient": {
			"types": "./dist/types/index.adminclient.d.ts",
			"import": "./dist/index.adminclient.js",
			"default": "./dist/index.adminclient.js"
		},
		"./config": {
			"types": "./dist/types/index.config.d.ts",
			"import": "./dist/index.config.js",
			"default": "./dist/index.config.js"
		},
		"./dist/components/*": "./dist/components/*",
		"./css/*": "./dist/css/*",
		"./scripts/*": "./dist/scripts/*"
	},
	"browser": {
		"fs": false,
		"path": false
	},
	"scripts": {
		"build": "bash src/scripts/build.sh",
		"lint": "eslint --fix",
		"create-pixelated-app": "node src/scripts/create-pixelated-app.js",
		"zip-theme": "node src/scripts/zip-pixelated-theme.js ../pixelated-blog-wp-theme Pixelated.zip",
		"validate-exports": "npx tsx src/scripts/validate-exports.js",
		"storybook": "rm -rf node_modules/.cache && storybook dev -p 6006",
		"buildStorybook": "rm -rf node_modules/.cache && NODE_OPTIONS=\"--max-old-space-size=8192\" storybook build",
		"test-storybook": "npx storybook test -c .storybook",
		"test:validator": "node src/scripts/test-validator.js",
		"test": "npm run test:validator && vitest run --silent",
		"test:ui": "vitest --ui",
		"test:coverage": "npm run test:validator && vitest run --coverage",
		"test:watch": "vitest",
		"config:vault": "npx tsx $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/config-vault.js\"))')",
		"config:encrypt": "npm run config:vault -- encrypt src/config/pixelated.config.json",
		"config:decrypt": "npm run config:vault -- decrypt src/config/pixelated.config.json.enc",
		"config:postbuild": "npm run config:vault -- postbuild",
		"release:prep": "node src/scripts/release-prep.js",
		"release": "bash $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/release.sh\"))')",
		"publish": "bash $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/publish.sh\"))')",
		"update": "bash $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/update.sh\"))')"
	},
	"dependencies": {
		"@aws-sdk/client-amplify": "^3.1032.0",
		"@aws-sdk/client-iam": "^3.1032.0",
		"date-fns": "^4.1.0",
		"globals": "^17.5.0",
		"html-entities": "^2.6.0",
		"next": "^16.2.4",
		"prop-types": "^15.8.1",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/helper-plugin-utils": "^7.28.6",
		"@babel/plugin-proposal-class-properties": "^7.18.6",
		"@babel/plugin-proposal-object-rest-spread": "^7.20.7",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@eslint/js": "9.39.4",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-webpack5-compiler-babel": "^4.0.1",
		"@storybook/preset-scss": "^1.0.3",
		"@storybook/react-dom-shim": "^10.1.4",
		"@storybook/react-webpack5": "^10.3.5",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/md5": "^2.3.6",
		"@types/node": "^25.6.0",
		"@types/prop-types": "^15.7.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.4",
		"@vitest/ui": "^4.1.4",
		"ajv": "^8.18.0",
		"ajv-keywords": "^5.1.0",
		"babel-loader": "^10.1.1",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^14.0.0",
		"css-loader": "^7.1.4",
		"eslint": "9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"file-loader": "^6.2.0",
		"glob": "^10.5.0",
		"happy-dom": "^20.8.9",
		"jsdom": "^29.0.2",
		"less-loader": "^12.3.2",
		"mini-css-extract-plugin": "^2.10.2",
		"null-loader": "^4.0.1",
		"react-test-renderer": "^19.2.5",
		"sass": "^1.99.0",
		"sass-loader": "^16.0.7",
		"storybook": "^10.3.5",
		"style-loader": "^4.0.0",
		"ts-loader": "^9.5.7",
		"typescript": "^6.0.3",
		"url-loader": "^4.1.1",
		"vitest": "^4.1.4",
		"webpack": "^5.106.2",
		"webpack-dev-server": "^5.2.3",
		"webpack-node-externals": "^3.0.0"
	},
	"overrides": {
		"flatted": "^3.4.2"
	},
	"peerDependencies": {
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"optionalDependencies": {
		"@aws-sdk/client-cloudwatch": "^3.1032.0",
		"@aws-sdk/client-route-53": "^3.1032.0",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^14.0.0",
		"googleapis": "^171.4.0",
		"md5": "^2.3.0",
		"puppeteer": "^24.42.0",
		"recharts": "^3.8.1"
	}
}
