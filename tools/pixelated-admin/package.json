{
	"name": "pixelated-admin",
	"version": "1.3.2",
	"private": true,
	"scripts": {
		"dev": "npm run clean && NODE_OPTIONS='--inspect' next dev --webpack -p 3006 --experimental-https",
		"build": "npm run clean && NODE_ENV=production next build --webpack",
		"start": "npm run clean && next build --webpack && next start",
		"lint": "eslint --fix",
		"clean": "rm -rf .next && rm -rf out",
		"test": "vitest run --silent",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"generate-site-images": "node $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/generate-site-images.js\"))')",
		"config:vault": "npx tsx $(node -e 'console.log(require.resolve(\"@pixelated-tech/components/scripts/config-vault.js\"))') postbuild",
		"config:encrypt": "npm run config:vault -- encrypt src/app/config/pixelated.config.json",
		"config:decrypt": "npm run config:vault -- decrypt src/app/config/pixelated.config.json.enc",
		"release:prep": "npm run update && npm run lint && npm run build",
		"release": "./node_modules/@pixelated-tech/components/dist/scripts/release.sh",
		"update": "bash node_modules/@pixelated-tech/components/dist/scripts/update.sh"
	},
	"dependencies": {
		"@auth/core": "^0.34.3",
		"@aws-sdk/client-cloudwatch": "^3.1026.0",
		"@aws-sdk/client-route-53": "^3.1026.0",
		"@pixelated-tech/components": "^3.15.1",
		"axe-core": "^4.11.2",
		"googleapis": "^171.4.0",
		"next": "^16.2.2",
		"next-auth": "^4.24.7",
		"prop-types": "^15.8.1",
		"puppeteer": "^24.40.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"recharts": "^3.8.1",
		"sass": "^1.99.0",
		"ssh2": "^1.17.0"
	},
	"overrides": {},
	"devDependencies": {
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.5.2",
		"@types/prop-types": "^15.7.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19",
		"@types/ssh2": "^1.15.5",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.3",
		"eslint": "9.39.4",
		"eslint-config-next": "^16.2.2",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"jsdom": "^29.0.2",
		"typescript": "^6.0.2",
		"vitest": "^4.1.3"
	}
}
