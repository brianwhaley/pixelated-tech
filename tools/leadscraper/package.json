{
	"name": "leadscraper",
	"version": "2.4.5",
	"private": true,
	"scripts": {
		"dev": "npm run clean && NODE_OPTIONS='--inspect' next dev --webpack -p 3002 --experimental-https",
		"build": "npm run clean && NODE_ENV=production next build --webpack",
		"start": "npm run clean && next build --webpack && next start",
		"lint": "eslint --fix",
		"clean": "rm -rf .next && rm -rf out",
		"update": "bash node_modules/@pixelated-tech/components/dist/scripts/update.sh"
	},
	"dependencies": {
		"@pixelated-tech/components": "*",
		"md5": "^2.3.0",
		"next": "^16.2.2",
		"puppeteer": "^24.40.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"sass": "^1.99.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.2.0",
		"eslint-config-next": "^16.2.2",
		"typescript": "^6.0.2"
	},
	"overrides": {
		"@aws-sdk/xml-builder": {
			"fast-xml-parser": "^5.3.4"
		}
	}
}
